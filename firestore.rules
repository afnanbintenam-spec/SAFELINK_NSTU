rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read and write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }
    
    // Allow authenticated users to read all user documents (for staff to see student profiles)
    match /users/{userId} {
      allow read: if request.auth != null;
    }
    
    // Allow any signed-in user to read/write notifications and alerts
    match /users/{userId}/notifications/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /users/{userId}/alerts/{docId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow access to alerts and incidents for authenticated users
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
    }
    
    match /incidents/{incidentId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow proctorial body to read all alerts
    match /proctorial_alerts/{alertId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // SMS and Call Logs
    match /sms_logs/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /call_logs/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
